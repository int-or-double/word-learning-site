<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Панель управления - TrainingCards</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="nav-brand">TrainingCards</div>
            <div class="nav-links" id="navLinks">
                <a href="/">Главная</a>
                <a href="/training">Тренировка</a>
                <a href="/about">О нас</a>
                <a href="/contact">Контакты</a>
                <% if (typeof user !== 'undefined' && user) { %>
                    <a href="/dashboard" class="btn-universal btn-template-1">Профиль</a>
                    <a href="/sets" class="btn-universal btn-template-1">Наборы</a>
                    <a href="/logout" class="btn-universal btn-template-2">Выйти</a>
                <% } else { %>
                    <a href="/login" class="btn-universal btn-template-1">Войти</a>
                    <a href="/register" class="btn-universal btn-template-2">Регистрация</a>
                <% } %>
            </div>
            
            <div class="burger-menu" id="burgerMenu">
                <div class="burger-line"></div>
                <div class="burger-line"></div>
                <div class="burger-line"></div>
            </div>
        </nav>
    </header>


    <main>
        <section class="about-page">
            <div class="container">
                <h1>Панель управления</h1>
                
                <div class="about-content">
                    <div class="dashboard-stats">
                        <h2>Ваша статистика</h2>
                        <div class="stats-grid">
                            <div class="stat-card">
                                <h3>📚 Наборы карточек</h3>
                                <p class="stat-number" id="setsCount">0</p>
                            </div>
                            <div class="stat-card">
                                <h3>🃏 Всего карточек</h3>
                                <p class="stat-number" id="cardsCount">0</p>
                            </div>
                            <div class="stat-card">
                                <h3>🏆 Выучено</h3>
                                <p class="stat-number">0</p>
                            </div>
                        </div>
                    </div>

                    <div class="dashboard-actions">
                        <h2>Управление вашими данными</h2>
                        <div class="action-buttons">
                            <a href="/sets" class="btn-universal btn-template-1 btn-large">
                                Управление наборами
                            </a>
                            <a href="/training" class="btn-universal btn-template-2 btn-large">
                                Начать тренировку
                            </a>
                        </div>
                    </div>

                    <div class="welcome-section">
                        <div class="mission-statement">
                            <h3>Добро пожаловать в TrainingCards!</h3>
                            <p>Создавайте свои наборы карточек для эффективного обучения.</p>
                            <p class="cta-text">Перейдите в раздел "Наборы" чтобы начать создавать свои карточки!</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <footer>
        <div class="footer-content">
            <p>&copy; 2025 TrainingCards. Все права защищены.</p>
            <div class="footer-links">
                <a href="/about">О нас</a>
                <a href="/contact">Контакты</a>
            </div>
        </div>
    </footer>

    <script src="/js/burger.js"></script>
    <script>
        // Загрузка статистики при загрузке страницы
        document.addEventListener('DOMContentLoaded', function() {
            loadStats();
        });

        // Загрузка статистики пользователя
        async function loadStats() {
            try {
                // Загружаем количество наборов
                const setsResponse = await fetch('/api/sets');
                const setsResult = await setsResponse.json();
                
                if (setsResult.success) {
                    document.getElementById('setsCount').textContent = setsResult.sets.length;
                    
                    // Считаем общее количество карточек
                    let totalCards = 0;
                    setsResult.sets.forEach(set => {
                        totalCards += set.card_count || 0;
                    });
                    document.getElementById('cardsCount').textContent = totalCards;
                }
            } catch (error) {
                console.error('Ошибка загрузки статистики:', error);
            }
        }
    </script>
</body>
</html>
