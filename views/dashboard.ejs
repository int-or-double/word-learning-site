<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Панель управления - WordLearn</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header>
		<nav class="navbar">
			<div class="nav-brand">TrainingCards</div>
			<div class="nav-links">
				<a href="/">Главная</a>
				<a href="/dashboard">Панель</a>
				<a href="/about">О нас</a>
				<a href="/contact">Контакты</a>
				
				<!-- Бургер-меню для мобильных -->
			<div class="burger-menu" id="burgerMenu">
				<div class="burger-line"></div>
				<div class="burger-line"></div>
				<div class="burger-line"></div>
			</div>

				<% if (typeof user !== 'undefined' && user) { %>
					<span>Привет, <%= user.username %>!</span>
					<a href="/logout" class="btn-universal btn-template-2">Выйти</a>
				<% } else { %>
					<a href="/login" class="btn-universal btn-template-1">Войти</a>
					<a href="/register" class="btn-universal btn-template-2">Регистрация</a>
				<% } %>
			</div>
		</nav>
	</header>



    <main>
        <section class="dashboard">
            <h1>Ваша панель управления</h1>
            
            <div class="dashboard-stats">
                <div class="stat-card">
                    <h3>Изучаемые слова</h3>
                    <p><%= words.length %></p>
                </div>
                <div class="stat-card">
                    <h3>Сегодня на повторение</h3>
                    <p>0</p>
                </div>
                <div class="stat-card">
                    <h3>Выучено</h3>
                    <p>0</p>
                </div>
            </div>

            <div class="words-section">
                <h2>Ваши слова</h2>
                <button class="btn btn-primary" onclick="addWord()">Добавить слово</button>
                
                <div class="word-cards">
                    <% words.forEach(word => { %>
                    <div class="word-card">
                        <h3><%= word.word %></h3>
                        <p class="translation"><%= word.translation %></p>
                        <p class="example"><%= word.example %></p>
                        <div class="word-actions">
                            <button class="btn btn-outline">Изучаю</button>
                            <button class="btn btn-primary">Выучил</button>
                        </div>
                    </div>
                    <% }); %>
                </div>
            </div>
        </section>
    </main>

    <footer>
        <div class="footer-content">
            <p>&copy; 2025 WordLearn. Все права защищены.</p>
            <div class="footer-links">
                <a href="/about">О нас</a>
                <a href="/contact">Контакты</a>
            </div>
        </div>
    </footer>
	<script src="/js/burger.js"></script>
    <script src="/js/main.js"></script>
	

    <script>
        function addWord() {
            alert('Функция добавления слов будет реализована позже!');
        }
    </script>
</body>
</html>

