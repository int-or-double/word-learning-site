<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TrainingCards - Карточки для обучения</title>
    <link rel="stylesheet" href="/css/style.css">
	
	

</head>
<body>
    <header>
		<nav class="navbar">
			<div class="nav-brand">TrainingCards</div>
			
			<!-- Обычное меню для десктопа -->
			<div class="nav-links" id="navLinks">
				<a href="/">Главная</a>
				<a href="/training">Тренировка</a>
				<a href="/about">О нас</a>
				<a href="/contact">Контакты</a>
				<a href="/login" class="btn-universal btn-template-1">Войти</a>
				<a href="/register" class="btn-universal btn-template-2">Регистрация</a>
			</div>
			
			<!-- Бургер-меню для мобильных -->
			<div class="burger-menu" id="burgerMenu">
				<div class="burger-line"></div>
				<div class="burger-line"></div>
				<div class="burger-line"></div>
			</div>
		</nav>
	</header>






    <main>
        <section class="hero">
            <div class="hero-content">
                <h1>TrainingCards - Учись с умом!</h1>
                <p>Интерактивные карточки-перевертыши для эффективного запоминания</p>
                <div class="hero-buttons">
					<a href="/register" class="btn-universal btn-template-1 hero-btn">
						Начать учиться
					</a>
					<a href="/training" class="btn-universal btn-template-2 hero-btn">
						Попробовать демо
					</a>
				</div>


				 
            </div>
        </section>

        <section class="features">
            <h2>Как это работает</h2>
            <div class="cards">
                <div class="card">
                    <div class="card-icon">🃏</div>
                    <h3>Карточки-перевертыши</h3>
                    <p>Кликни на карточку, чтобы увидеть объяснение</p>
                </div>
                <div class="card">
                    <div class="card-icon">⏱️</div>
                    <h3>Автоматический переворот</h3>
                    <p>Карточка переворачивается обратно через 8 секунд</p>
                </div>
                <div class="card">
                    <div class="card-icon">📊</div>
                    <h3>Система запоминания</h3>
                    <p>Интервальное повторение для лучшего усвоения</p>
                </div>
            </div>
        </section>

        <section class="examples">
			<h2>Пора действовать: кликните по карточке!</h2>
			<div class="card-container">
				<% cards.forEach(card => { %>
				<div class="flip-card">
					<div class="flip-card-inner">
						<div class="flip-card-front">
							<h3><%= card.front %></h3>
						</div>
						<div class="flip-card-back">
							<p class="explanation">Объяснение: <%= card.back %></p>
							<% if (card.note) { %>
							<p class="note">Справка: <%= card.note %></p>
							<% } %>
						</div>
					</div>
				</div>
				<% }); %>
			</div>
		</section>


    </main>

    <footer>
        <div class="footer-content">
            <p>&copy; 2025 TrainingCards. Все права защищены.</p>
            <div class="footer-links">
                <a href="/about">О нас</a>
                <a href="/contact">Контакты</a>
            </div>
        </div>
    </footer>
	<script src="/js/burger.js"></script>
    <script src="/js/main.js"></script>

</body>
</html>
